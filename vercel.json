{
  "buildCommand": "npm run build",
  "headers": [
    {
      "source": "/widget-embed-iframe.html",
      "headers": [
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS, HEAD" },
        { "key": "Access-Control-Allow-Headers", "value": "*" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.wazapp.ai" }],
      "destination": "https://wazapp.ai/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "cmr-chatbot-two.vercel.app" }],
      "destination": "https://wazapp.ai/:path*",
      "permanent": true
    }
  ]
}
